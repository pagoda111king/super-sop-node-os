{
  "schema_version": 1,
  "project": "SOP工厂",
  "name": "Super SOP Factory Node Visual System",
  "updated_at": "2026-06-12",
  "purpose": "给 6 层 14 类节点建立稳定颜色、图形隐喻和动画语义，供项目台节点看板、OpenMAIC 教案、知识对战和客户表达复用。",
  "brain_science_basis": [
    {
      "principle": "color_coding",
      "source": "/Users/tanghuiwen/工作/雷达/脑科学lab/research/03_visual_design_for_memory/color_coding_psychology.md",
      "rule": "颜色必须有语义且全系统一致，不能作为装饰。"
    },
    {
      "principle": "cognitive_load",
      "source": "/Users/tanghuiwen/工作/雷达/脑科学lab/visual_principles/cognitive_load_theory.md",
      "rule": "每屏默认突出 3-4 个 chunk，其余弱化或分阶段揭示。"
    },
    {
      "principle": "dual_coding",
      "source": "/Users/tanghuiwen/工作/雷达/脑科学lab/visual_principles/dual_coding_theory.md",
      "rule": "节点必须同时有文字、颜色、形状或图标隐喻。"
    },
    {
      "principle": "animation_for_learning",
      "source": "/Users/tanghuiwen/工作/雷达/脑科学lab/research/03_visual_design_for_memory/animation_for_learning.md",
      "rule": "动画只用于流程、因果链和状态流转。"
    },
    {
      "principle": "infographic_data_ink",
      "source": "/Users/tanghuiwen/工作/雷达/脑科学lab/research/03_visual_design_for_memory/infographic_principles.md",
      "rule": "视觉元素必须承载信息，减少无意义装饰。"
    }
  ],
  "macro_layers": [
    {
      "id": "L1",
      "name": "输入捕获层",
      "role": "把混沌输入变成任务对象",
      "nodes": ["intake_node"]
    },
    {
      "id": "L2",
      "name": "上下文与记忆层",
      "role": "加载任务相关历史、约束和长期记忆",
      "nodes": ["context_memory_node"]
    },
    {
      "id": "L3",
      "name": "认知编排层",
      "role": "查找、整理、建模、计划、路由和学习",
      "nodes": ["radar_node", "evidence_normalize_node", "data_modeling_node", "planning_node", "routing_node", "learning_node"]
    },
    {
      "id": "L4",
      "name": "行动执行层",
      "role": "调用工具和系统完成真实动作",
      "nodes": ["action_node"]
    },
    {
      "id": "L5",
      "name": "验证治理层",
      "role": "测试、评分、检查、权限和风险治理",
      "nodes": ["test_node", "score_node", "check_node"]
    },
    {
      "id": "L6",
      "name": "沉淀资产层",
      "role": "交付、复盘和复利资产回写",
      "nodes": ["handoff_node", "sediment_node"]
    }
  ],
