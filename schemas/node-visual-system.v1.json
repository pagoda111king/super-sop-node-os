  "animation_rules": {
    "allowed": ["flow pulse", "node activation", "risk gate flash", "sediment growth"],
    "not_allowed": ["decorative flying text", "unrelated background motion", "constant high saturation flashing"],
    "default_cycle_seconds": 14,
    "reduced_motion": "show static graph and disable pulse"
  }
